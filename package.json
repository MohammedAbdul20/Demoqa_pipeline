{
  "name": "playwright_practice_cucumber",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js --require \"stepDefintions/**/*.js\" --require \"utilities/hooks/**/*.js\" --format json:reports/cucumber-report.json --format progress --format progress --format summary --format allure-cucumberjs/reporter",
    "test-see-html" : "npx cucumber-js --require stepDefintions/**/*.js --require utilities/hooks/**/*.js",
    "codegen": "npx playwright codegen",
    "allure:report": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report",
    "test:ui": "npx playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.42.0",
    "allure-cucumberjs": "^3.9.0"
  },
  "dependencies": {
    "@cucumber/cucumber": "^13.0.0"
  }
}
